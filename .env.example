TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOWED_USER_ID=123456789
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8081
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false
# Docker default: localhost:55433
# No-Docker local PostgreSQL example: postgresql+asyncpg://postgres:postgres@localhost:5432/tg_kb
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:55433/tg_kb
BACKUP_DIR=backups
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore
ADMIN_API_ENABLED=false
ADMIN_API_HOST=127.0.0.1
ADMIN_API_PORT=8080
ADMIN_API_TOKEN=change_me_admin_token
ADMIN_EXPORT_DIR=exports
SEMANTIC_SEARCH_ENABLED=false
SEMANTIC_PROVIDER=openai
SEMANTIC_MODEL=text-embedding-3-small
SEMANTIC_EMBEDDING_DIM=1536
SEMANTIC_ALPHA=0.35
SEMANTIC_TOP_K_CANDIDATES=100
SEMANTIC_MIN_SCORE=0.0
SEMANTIC_TIMEOUT_MS=3000
OPENAI_API_KEY=
OPENAI_BASE_URL=
LOCAL_EMBEDDING_URL=
