TELEGRAM_BOT_TOKEN=__SET_IN_SECRET_MANAGER__
TELEGRAM_ALLOWED_USER_ID=__YOUR_TELEGRAM_USER_ID__
DATABASE_URL=postgresql+asyncpg://__DB_USER__:__DB_PASSWORD__@__DB_HOST__:5432/__DB_NAME__
BACKUP_DIR=/var/lib/tg_kb/backups
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore
ADMIN_API_ENABLED=true
ADMIN_API_HOST=127.0.0.1
ADMIN_API_PORT=8080
ADMIN_API_TOKEN=__SET_IN_SECRET_MANAGER__
ADMIN_EXPORT_DIR=/var/lib/tg_kb/exports
